rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User pointer doc and old data path — only the user themselves can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Invite lookup — readable by any authenticated user (needed at sign-in),
    // writable only by org admins (enforced in org rules below) and by the
    // invited user accepting their own invite
    match /inviteLookup/{emailKey} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Org rules
    match /orgs/{orgId} {

      // Helper: is the requesting user a member of this org?
      function isMember() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid));
      }

      // Helper: get the requesting user's role
      function memberRole() {
        return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data.role;
      }

      function isAdmin() { return isMember() && memberRole() == 'admin'; }
      function isEmployee() { return isMember() && memberRole() == 'employee'; }
      function isCustomer() { return isMember() && memberRole() == 'customer'; }

      // Org doc — invite-only: no self-created orgs. Members can read, admins can update.
      // (To enable self-signup, change create to: if request.auth != null — see HANDOFF.md)
      allow read: if isMember();
      allow create: if false;
      allow update, delete: if isAdmin();

      // Helper: the requester's pending invite doc (inviteLookup keyed by email,
      // lowercased with dots replaced by commas). Only admins write inviteLookup rows
      // with an orgId, so this is trusted.
      function inviteFor() {
        return get(/databases/$(database)/documents/inviteLookup/$(request.auth.token.email.lower().replace('\\.', ',')));
      }

      // Members subcollection
      match /members/{memberId} {
        allow read: if isMember() || request.auth.uid == memberId;
        // Admins manage members freely
        allow write: if isAdmin();
        // A user may create ONLY their own member doc, ONLY with a pending invite
        // for this org, and ONLY with the role the admin chose in that invite.
        allow create: if request.auth != null &&
          request.auth.uid == memberId &&
          request.auth.token.email != null &&
          inviteFor().data.orgId == orgId &&
          request.resource.data.role == inviteFor().data.role;
      }

      // Invites subcollection — admin only, except the invited user may
      // delete their own invite doc while accepting it at sign-in
      // (doc ID = email lowercased with dots replaced by commas).
      match /invites/{inviteId} {
        allow read, create, update: if isAdmin();
        allow delete: if isAdmin() ||
          (request.auth != null && request.auth.token.email != null &&
           inviteId == request.auth.token.email.lower().replace('\\.', ','));
      }

      // Settings — members can read, only admins can write
      match /settings/{doc} {
        allow read: if isMember();
        allow write: if isAdmin();
      }

      // Customers — admin only
      match /customers/{customerId} {
        allow read, write: if isAdmin();
      }

      // Notes
      match /notes/{noteId} {
        // Admin sees everything
        allow read: if isAdmin();
        // Employee and customer can only read if explicitly assigned
        allow read: if (isEmployee() || isCustomer()) &&
          ('assignedTo' in resource.data) &&
          request.auth.uid in resource.data.assignedTo;
        // Admin can create/update/delete anything
        allow create, update, delete: if isAdmin();
        // Employee can create GENERAL notes only (no customerId), self-assigned
        allow create: if isEmployee() &&
          request.resource.data.customerId == null &&
          request.resource.data.assignedTo is list &&
          request.auth.uid in request.resource.data.assignedTo;
        // Employee can update notes assigned to them, but not change the assignment
        allow update: if isEmployee() &&
          ('assignedTo' in resource.data) &&
          request.auth.uid in resource.data.assignedTo &&
          request.resource.data.assignedTo == resource.data.assignedTo;
        // Employees and customers can never delete
      }
    }
  }
}
